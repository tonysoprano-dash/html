<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dynamic Pricing Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #4f46e5;
            --bg: #f9fafb;
            --card: #ffffff;
        }
        body { font-family: 'Pretendard', sans-serif; background: var(--bg); margin: 0; padding: 20px; }
        .container { max-width: 1000px; margin: 0 auto; }
        header { margin-bottom: 30px; border-bottom: 2px solid #eee; padding-bottom: 10px; }
        
        /* 대시보드 그리드 */
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .card { background: var(--card); padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        
        /* 실시간 수치 강조 */
        .stat-value { font-size: 2rem; font-weight: bold; color: var(--primary); }
        .price-up { color: #ef4444; }
        .price-down { color: #3b82f6; }

        /* 컨트롤 패널 */
        .controls { margin-top: 20px; display: flex; gap: 10px; }
        button { padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; background: var(--primary); color: white; font-weight: bold; }
        
        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>실시간 유동 인구 기반 동적 가격 설정</h1>
        <p>인구 밀집도에 따라 자동으로 가격이 조정되는 시스템 시뮬레이션</p>
    </header>

    <div class="grid">
        <div class="card">
            <h3>현재 상태</h3>
            <div>현재 유동 인구: <span id="current-pop" class="stat-value">0</span> 명</div>
            <div style="margin-top: 10px;">적용 가격: <span id="current-price" class="stat-value">₩10,000</span></div>
            <p id="price-status">데이터 분석 중...</p>
        </div>

        <div class="card">
            <h3>가격 변동 트렌드</h3>
            <canvas id="priceChart"></canvas>
        </div>

        <div class="card" style="grid-column: span 2;">
            <h3>시뮬레이션 컨트롤</h3>
            <p>유동 인구 변화 시나리오를 수동으로 조절해보세요.</p>
            <input type="range" id="pop-slider" min="0" max="1000" value="500" style="width: 80%;">
            <span id="slider-val">500명</span>
            
            <div class="controls">
                <button onclick="toggleAuto()">자동 시뮬레이션 ON/OFF</button>
            </div>
        </div>
    </div>
</div>

<script>
    // 기본 데이터 초기화
    const basePrice = 10000;
    let population = 500;
    let history = { labels: [], prices: [], pops: [] };
    let isAuto = true;

    // Chart.js 설정
    const ctx = document.getElementById('priceChart').getContext('2d');
    const chart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: history.labels,
            datasets: [{
                label: '실시간 가격 (원)',
                data: history.prices,
                borderColor: '#4f46e5',
                tension: 0.3,
                fill: true,
                backgroundColor: 'rgba(79, 70, 229, 0.1)'
            }]
        },
        options: { responsive: true, scales: { y: { beginAtZero: false } } }
    });

    // 핵심 로직: 유동 인구에 따른 가격 계산 함수
    function calculatePrice(pop) {
        // 간단한 알고리즘: 기준인원(500명)보다 10명 많을 때마다 1% 가격 상승
        let multiplier = 1 + (pop - 500) / 1000;
        return Math.floor(basePrice * multiplier);
    }

    function updateUI() {
        const price = calculatePrice(population);
        const statusEl = document.getElementById('price-status');
        
        // UI 업데이트
        document.getElementById('current-pop').innerText = population;
        document.getElementById('current-price').innerText = `₩${price.toLocaleString()}`;
        
        if(population > 700) {
            statusEl.innerText = "⚠️ 인구 밀집: 프리미엄 요금 적용 중";
            statusEl.className = "price-up";
        } else if(population < 300) {
            statusEl.innerText = "✅ 인구 적음: 할인 요금 적용 중";
            statusEl.className = "price-down";
        } else {
            statusEl.innerText = "정상 범위 운용 중";
            statusEl.className = "";
        }

        // 차트 데이터 추가
        const now = new Date();
        const timeStr = `${now.getHours()}:${now.getMinutes()}:${now.getSeconds()}`;
        
        chart.data.labels.push(timeStr);
        chart.data.datasets[0].data.push(price);
        
        if(chart.data.labels.length > 10) {
            chart.data.labels.shift();
            chart.data.datasets[0].data.shift();
        }
        chart.update();
    }

    // 슬라이더 이벤트
    document.getElementById('pop-slider').addEventListener('input', (e) => {
        population = parseInt(e.target.value);
        document.getElementById('slider-val').innerText = population + "명";
        if(!isAuto) updateUI();
    });

    function toggleAuto() { isAuto = !isAuto; }

    // 자동 시뮬레이션 루프
    setInterval(() => {
        if(isAuto) {
            // 유동 인구의 무작위 변화 시뮬레이션
            let change = Math.floor(Math.random() * 100) - 50;
            population = Math.max(0, Math.min(1000, population + change));
            document.getElementById('pop-slider').value = population;
            document.getElementById('slider-val').innerText = population + "명";
            updateUI();
        }
    }, 2000);

    updateUI(); // 초기 실행
</script>

</body>
</html>
